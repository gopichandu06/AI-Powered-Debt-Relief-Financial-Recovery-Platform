# FinRelief AI Environment Variables
# Copy this file to .env and fill in your values

# ─── Security ────────────────────────────────────────────────
# REQUIRED: Change this to a random 32+ character string in production
SECRET_KEY=change-this-to-a-secure-random-string-min-32-characters

# JWT algorithm (do not change)
ALGORITHM=HS256

# JWT token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database ────────────────────────────────────────────────
# SQLite (development): sqlite:///./finrelief.db
# PostgreSQL (production): postgresql://user:password@host:5432/finrelief
DATABASE_URL=sqlite:///./finrelief.db

# ─── Google Gemini AI ────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com
# Must start with "AIzaSy..." — leave empty to use rule-based fallback
GEMINI_API_KEY=

# ─── Application ─────────────────────────────────────────────
APP_NAME=FinRelief AI
APP_VERSION=1.0.0
DEBUG=false

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:80"]
